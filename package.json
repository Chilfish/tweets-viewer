{
  "name": "tweets-viewer",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "packageManager": "bun@1.3.13",
  "scripts": {
    "dev": "concurrently \"bun run dev:server\" \"bun run dev:client\"",
    "dev:server": "bun run --cwd ./apps/server dev",
    "dev:client": "bun run --cwd ./apps/web-react dev",
    "build:client": "bun run --cwd ./apps/web-react build",
    "deploy": "bun run --cwd ./apps/server deploy",
    "lint": "eslint . --fix"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "dependencies": {
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.1",
    "eslint-plugin-format": "^2.0.1",
    "lefthook": "^2.1.6",
    "lint-staged": "^16.4.0",
    "typescript": "^6.0.3"
  }
}
